{
  "__inputs": [{ "name": "DS_PROMETHEUS", "type": "datasource", "pluginId": "prometheus" }],
  "title": "QuantEngine Platform",
  "uid": "quant-main",
  "schemaVersion": 38,
  "refresh": "10s",
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Active Backtest Runs",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(quant_backtest_runs_active)", "datasource": "DS_PROMETHEUS" }],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "orange", "value": 5 }] }
      }}
    },
    {
      "id": 2, "type": "stat", "title": "Redis Queue Depth",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "redis_list_length{key=\"backtest_queue\"}", "datasource": "DS_PROMETHEUS" }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 20 }] }
      }}
    },
    {
      "id": 3, "type": "stat", "title": "API p99 Latency (ms)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m])) * 1000", "datasource": "DS_PROMETHEUS" }],
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "orange", "value": 500 }, { "color": "red", "value": 2000 }] }
      }}
    },
    {
      "id": 4, "type": "stat", "title": "Total Completed Runs",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(quant_backtest_runs_total{status=\"complete\"})", "datasource": "DS_PROMETHEUS" }],
      "options": { "colorMode": "value" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "blue", "mode": "fixed" } } }
    },
    {
      "id": 5, "type": "timeseries", "title": "API Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(http_requests_total[1m])", "legendFormat": "{{method}} {{handler}}", "datasource": "DS_PROMETHEUS" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 6, "type": "timeseries", "title": "Backtest Run Duration (ms)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(quant_backtest_duration_ms_bucket[5m]))", "legendFormat": "p50", "datasource": "DS_PROMETHEUS" },
        { "expr": "histogram_quantile(0.95, rate(quant_backtest_duration_ms_bucket[5m]))", "legendFormat": "p95", "datasource": "DS_PROMETHEUS" },
        { "expr": "histogram_quantile(0.99, rate(quant_backtest_duration_ms_bucket[5m]))", "legendFormat": "p99", "datasource": "DS_PROMETHEUS" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 7, "type": "timeseries", "title": "Runs by Status Over Time",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(quant_backtest_runs_total{status=\"complete\"}[5m])", "legendFormat": "complete", "datasource": "DS_PROMETHEUS" },
        { "expr": "rate(quant_backtest_runs_total{status=\"failed\"}[5m])",   "legendFormat": "failed",   "datasource": "DS_PROMETHEUS" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "complete" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "failed" },   "properties": [{ "id": "color", "value": { "fixedColor": "red",   "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 8, "type": "timeseries", "title": "Memory Usage — API Pods",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "container_memory_working_set_bytes{namespace=\"quant\", container=\"api\"} / 1024 / 1024", "legendFormat": "{{pod}}", "datasource": "DS_PROMETHEUS" }
      ],
      "fieldConfig": { "defaults": { "unit": "MiB" } }
    }
  ]
}
