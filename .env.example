# .env.example
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# .env is git-ignored. Never commit real credentials.

# ── API ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+asyncpg://quant:quant@localhost:5432/quant
DATA_DIR=./data
LOG_LEVEL=info

# ── Frontend ──────────────────────────────────────────────────
# URL the browser uses to reach the API.
# Local dev: http://localhost:8000
# Production: https://api.yourdomain.com
VITE_API_URL=http://localhost:8000

# ── Docker registry (used by scripts/deploy.sh) ───────────────
DOCKER_REGISTRY=your-dockerhub-username
IMAGE_TAG=latest
DOCKER_PUSH=false

# ── PostgreSQL (used inside docker-compose) ───────────────────
POSTGRES_USER=quant
POSTGRES_PASSWORD=quant
POSTGRES_DB=quant

# ── Grafana ───────────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=admin
